record(bo, "$(P)$(R)MyBoolVar") {
    field(VAL,  "1")
    field(ZNAM, "On")
    field(ZSV, "MAJOR")
    field(ONAM, "Off")
    field(PINI, "YES")
}

record(waveform, "$(P)$(R)MyWaveVar") {
    field(DESC, "description")
    field(NELM, "256")
    field(FTVL, "FLOAT")
    field(INP, "[2,3,5]")
    field(PINI, "YES")
    info("test_variable", "record")
}
